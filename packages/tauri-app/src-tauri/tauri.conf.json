{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openNetDrive",
  "version": "0.3.4",
  "identifier": "com.opennetdrive.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "openNetDrive - 网络驱动器挂载工具",
        "width": 800,
        "height": 750,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": false,
        "titleBarStyle": "hidden"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
