{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openNetDrive",
  "version": "0.2.0",
  "identifier": "com.opennetdrive.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "openNetDrive - 网络驱动器挂载工具",
        "width": 900,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 600,
        "minHeight": 550
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
